{
  "name": "@component-library/components",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly false",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18"
  },
  "dependencies": {
    "@component-library/primitives": "^0.1.0",
    "@component-library/hooks": "^0.1.0",
    "@component-library/utils": "^0.1.0",
    "@component-library/tokens": "^0.1.0"
  }
}
